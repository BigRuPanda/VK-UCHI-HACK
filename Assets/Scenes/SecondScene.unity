  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 25542b6f134668044adbb423d00a6e21, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ReadingModule.ReadingController
  sentences:
  - sentenceText: "\u042F\u0440\u043A\u043E\u0435 \u0441\u043E\u043B\u043D\u0446\u0435
      \u0441\u0438\u044F\u043B\u043E, \u0438\u0433\u0440\u0430\u044F \u0437\u043E\u043B\u043E\u0442\u044B\u043C\u0438
      \u0438\u0441\u043A\u0440\u0430\u043C\u0438."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 809712801}
    objectsToDeactivate: []
  - sentenceText: "\u041F\u0443\u0448\u0438\u0441\u0442\u044B\u0435 \u043E\u0431\u043B\u0430\u043A\u0430
      \u043F\u043B\u044B\u043B\u0438 \u043F\u043E \u043D\u0435\u0431\u0443, \u0441\u043B\u043E\u0432\u043D\u043E
      \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u0431\u0435\u043B\u044B\u0435
      \u043A\u043E\u0440\u0430\u0431\u043B\u0438."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 784401399}
    objectsToDeactivate: []
  - sentenceText: "\u0412\u0435\u0441\u0451\u043B\u044B\u0435 \u0447\u0430\u0439\u043A\u0438
      \u043A\u0440\u0443\u0436\u0438\u043B\u0438 \u043D\u0430\u0434 \u0432\u043E\u0434\u043E\u0439,
      \u0433\u0440\u043E\u043C\u043A\u043E \u043A\u0440\u0438\u0447\u0430 \u0438
      \u043D\u044B\u0440\u044F\u044F \u0437\u0430 \u0440\u044B\u0431\u043A\u043E\u0439."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 437758152}
    objectsToDeactivate: []
  - sentenceText: "\u0421\u0438\u043D\u0435\u0435 \u043C\u043E\u0440\u0435 \u0448\u0443\u043C\u0438\u0442,
      \u0438 \u0435\u0433\u043E \u0432\u043E\u043B\u043D\u044B \u043C\u044F\u0433\u043A\u043E
      \u043F\u043B\u0435\u0449\u0443\u0442\u0441\u044F, \u0441\u0432\u0435\u0440\u043A\u0430\u044F
      \u043D\u0430 \u0441\u0432\u0435\u0442\u0443."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 1550691590}
    - {fileID: 527797940}
    objectsToDeactivate: []
  - sentenceText: "\u041F\u0438\u0440\u0430\u0442\u0441\u043A\u0438\u0439 \u043A\u043E\u0440\u0430\u0431\u043B\u044C!
      \u041E\u043D \u0431\u0440\u043E\u0441\u0430\u0435\u0442\u0441\u044F \u0432\u0435\u0441\u0451\u043B\u044B\u043C\u0438
      \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u0447\u0438\u043A\u0430\u043C\u0438!"
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 502210457}
    - {fileID: 1285262891}
    - {fileID: 652177108}
    objectsToDeactivate:
    - {fileID: 214185389}
    - {fileID: 90748190}
