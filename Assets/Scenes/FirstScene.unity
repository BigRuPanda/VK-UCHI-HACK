--- !u!114 &8310701542363159121
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4777357064436352253}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 25542b6f134668044adbb423d00a6e21, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ReadingModule.ReadingController
  sentences:
  - sentenceText: "\u0412\u043E\u043B\u0448\u0435\u0431\u043D\u043E\u0435 \u0431\u043E\u043B\u043E\u0442\u043E
      \u0445\u0440\u0430\u043D\u0438\u043B\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E,
      \u0442\u0430\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E \u0442\u0438\u0448\u0438\u043D\u0443."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 8559861356227578997}
    objectsToDeactivate: []
  - sentenceText: "\u0428\u0438\u0440\u043E\u043A\u0438\u0439 \u0440\u0443\u0447\u0435\u0439
      \u0436\u0443\u0440\u0447\u0430\u043B \u043C\u0435\u0436 \u043A\u0430\u043C\u043D\u0435\u0439,
      \u043F\u0440\u0435\u0433\u0440\u0430\u0436\u0434\u0430\u044F \u043F\u0443\u0442\u044C."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 684525092}
    objectsToDeactivate: []
  - sentenceText: "\u0412\u043E\u043A\u0440\u0443\u0433, \u0441\u043B\u043E\u0432\u043D\u043E
      \u0436\u0438\u0432\u044B\u0435 \u0438\u0441\u043A\u043E\u0440\u043A\u0438,
      \u043A\u0440\u0443\u0436\u0438\u043B\u0438 \u0432\u043E\u043B\u0448\u0435\u0431\u043D\u044B\u0435
      \u0437\u0435\u043B\u0451\u043D\u044B\u0435 \u0441\u0432\u0435\u0442\u043B\u044F\u0447\u043A\u0438."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 1365482158}
    objectsToDeactivate: []
  - sentenceText: "\u0422\u0443\u043C\u0430\u043D."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 2020947389}
    objectsToDeactivate: []
  - sentenceText: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0433\u0435\u0440\u043E\u0439
      \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F \u043D\u0430
      \u043A\u0440\u0430\u044E \u0431\u0435\u0440\u0435\u0433\u0430."
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 2904914715165772536}
    objectsToDeactivate: []
  - sentenceText: "\u041F\u043E\u043C\u043E\u0433\u0438 \u0433\u0435\u0440\u043E\u044E
      \u043F\u0435\u0440\u0435\u0439\u0442\u0438 \u0440\u0435\u043A\u0443 \u0438
      \u043F\u043E\u043F\u0430\u0441\u0442\u044C \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E
      \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0443 \u043A\u043D\u0438\u0433\u0438"
    voiceOver: {fileID: 0}
    objectsToUnlock:
    - {fileID: 5425845118731880354}
    - {fileID: 2510396303647325533}
    - {fileID: 587475193}
    - {fileID: 4587712246347929847}
    objectsToDeactivate:
    - {fileID: 4638413216977617817}
    - {fileID: 8693177923264250775}
    - {fileID: 5363528184751885243}
    - {fileID: 931502988}
    - {fileID: 4777357064436352253}
